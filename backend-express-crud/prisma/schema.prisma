// [Pertemuan 12-15] Schema Prisma menggantikan raw SQL query (mysql2) di
// versi sebelumnya. Semua tabel & relasi yang tadinya ditulis manual di
// sql/schema.sql sekarang didefinisikan di sini.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// [Pertemuan 12 - Bagian 1: Desain Database Relasi Mahasiswa dan Prodi]
model Prodi {
  id         Int        @id @default(autoincrement())
  namaProdi  String     @unique @map("nama_prodi") @db.VarChar(100)
  createdAt  DateTime   @default(now()) @map("created_at")
  mahasiswa  Mahasiswa[]

  @@map("prodi")
}

model Mahasiswa {
  id        Int      @id @default(autoincrement())
  nim       String   @unique @db.VarChar(20)
  nama      String   @db.VarChar(100)
  prodi     Prodi    @relation(fields: [prodiId], references: [id])
  prodiId   Int      @map("prodi_id")
  angkatan  Int
  foto      String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("mahasiswa")
}

// [Pertemuan 13 - Bagian 3: Tabel Users]
enum Role {
  admin
  operator
  viewer
}

model User {
  id                   Int                   @id @default(autoincrement())
  name                 String                @db.VarChar(100)
  email                String                @unique @db.VarChar(100)
  password             String                @db.VarChar(255)
  role                 Role                  @default(viewer)
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  passwordResetTokens  PasswordResetToken[]

  @@map("users")
}

// [Pertemuan 15 - Bagian 7: Opsi Reset Password via Email] (bonus/opsional)
model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int       @map("user_id")
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("password_reset_tokens")
}
